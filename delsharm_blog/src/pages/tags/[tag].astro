---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    const tagsMap = new Map();
    
    allPosts.forEach(post => {
        // Enforce tagging rule for untitled posts
        const title = post.data.title || "вҖ”";
        const tags = post.data.tags ? [...post.data.tags] : [];
        if (title === "вҖ”" && !tags.includes("ШіЫҢШ§ЩҮвҖҢЩ…ШҙЩӮ")) {
            tags.push("ШіЫҢШ§ЩҮвҖҢЩ…ШҙЩӮ");
        }

        tags.forEach(tag => {
            if (!tagsMap.has(tag)) {
                tagsMap.set(tag, []);
            }
            tagsMap.get(tag).push(post);
        });
    });

    return Array.from(tagsMap.entries()).map(([tag, posts]) => {
        // Safely sort posts chronologically
        posts.sort((a, b) => {
            const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
            const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
            return dateB - dateA;
        });
        return {
            params: { tag },
            props: { posts, allPosts }
        };
    });
}

const { tag } = Astro.params;
const { posts, allPosts } = Astro.props;

// Rebuild sidebar data for the sub-page
const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(post => {
    const pTitle = post.data.title || "вҖ”";
    const pTags = post.data.tags ? [...post.data.tags] : [];
    if (pTitle === "вҖ”" && !pTags.includes("ШіЫҢШ§ЩҮвҖҢЩ…ШҙЩӮ")) {
        pTags.push("ШіЫҢШ§ЩҮвҖҢЩ…ШҙЩӮ");
    }

    pTags.forEach(t => {
        tagCounts[t] = (tagCounts[t] || 0) + 1;
    });

    let archiveLabel = "ЩҶШ§Щ…ШҙШ®Шө";
    if (post.data.jalaliDate) {
        const parts = post.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archiveLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archiveLabel] = (archiveCounts[archiveLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
})).sort((a, b) => b.count - a.count);

function toFa(num: number) {
    const farsiDigits = ['Ы°','Ыұ','ЫІ','Ыі','Ыҙ','Ыө','Ы¶','Ы·','Ыё','Ы№'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

function extractImage(bodyStr: string) {
    const imgRegex = /<img[^>]+src=["'](.*?)["']|!\[.*?\]\((.*?)\)/i;
    const match = bodyStr.match(imgRegex);
    return match ? (match[1] || match[2]) : null;
}

function generateExcerpt(markdownBody: string) {
    if (!markdownBody) return "<p>ШЁШҜЩҲЩҶ Щ…ШӯШӘЩҲШ§</p>";
    let text = markdownBody.replace(/!\[.*?\]\(.*?\)/g, '').replace(/<img[^>]*>/g, '');
    const paragraphs = text.split(/\n\s*\n/).map(p => p.trim()).filter(p => p.length > 0);
    let excerptHtml = "";
    let currentLen = 0;
    
    for (let p of paragraphs) {
        p = p.replace(/\n/g, '<br>');
        p = p.replace(/^#+\s+/g, '');
        p = p.replace(/(\*\*|__)(.*?)\1/g, '$2');
        p = p.replace(/(\*|_)(.*?)\1/g, '$2');
        
        excerptHtml += `<p>${p}</p>`;
        currentLen += p.length;
        if (currentLen >= 350) break;
    }
    return excerptHtml || "<p>ШЁШҜЩҲЩҶ Щ…ШӯШӘЩҲШ§</p>";
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ШЁШұЪҶШіШЁ: {tag} | ШҜЩ„ШҙШұЩ…</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="ШӘШәЫҢЫҢШұ ШӘЩ…">рҹҢҷ</button>
            <a href="/delsharm" style="float: right; font-weight: bold;">вҶҗ ШЁШ§ШІЪҜШҙШӘ</a>
            <h1><a href="/delsharm" style="color: inherit; text-decoration: none;">ШҜЩ„ШҙШұЩ…</a></h1>
            <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">Щ…ШӯЩ…ШҜШөШ§ШҜЩӮ ШұШіЩҲЩ„ЫҢ</p>
            <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 20px 0;">
            <h2 style="margin: 0; font-size: 1.5em; text-align: center;">ЩҶЩҲШҙШӘЩҮвҖҢЩҮШ§ЫҢ ШҜШ§ШұШ§ЫҢ ШЁШұЪҶШіШЁ: {tag}</h2>
            <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; text-align: center;">{toFa(posts.length)} ЩҶЩҲШҙШӘЩҮ ЫҢШ§ЩҒШӘ ШҙШҜ</p>
        </div>
        
        <div class="main-layout">
            <div class="content-area">
                <div class="posts-grid">
                    
                    {posts.map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/delsharm/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="ШӘШөЩҲЫҢШұ ЩҫШіШӘ" />
                                </a>
                            )}
                            <div class="card-content">
                                <h2><a href={`/delsharm/blog/${post.id}/`}>{post.data.title}</a></h2>
                                
                                {post.data.jalaliDate && (
                                    <div class="date">{post.data.jalaliDate}</div>
                                )}
                                
                                <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                
                                <a href={`/delsharm/blog/${post.id}/`} class="read-more">Ш§ШҜШ§Щ…ЩҮ Щ…Ш·Щ„ШЁ вҶҗ</a>
                            </div>
                        </div>
                    ))}
                    
                </div>
            </div>

            <div class="sidebar-area">
                <div class="section-title">Щ…ЩҲШ¶ЩҲШ№Ш§ШӘ ЩҫШұШ·ШұЩҒШҜШ§Шұ</div>
                <div class="tags-grid">
                    {sortedTags.map(([t, count]) => (
                        <a href={`/delsharm/tags/${t}/`} class="tag-tile">
                            <span class="tag-name">{t}</span>
                            <span class="tag-count">{toFa(count)}</span>
                        </a>
                    ))}
                </div>
                
                <div class="section-title">ШЁШ§ЫҢЪҜШ§ЩҶЫҢ Щ…Ш§ЩҮШ§ЩҶЩҮ</div>
                <div class="tags-grid">
                    {sortedArchives.map(arch => (
                        <a href={`/delsharm/baygani/${arch.label}/`} class="baygani-tile">
                            <span class="tag-name">{arch.label}</span>
                            <span class="tag-count">{toFa(arch.count)}</span>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </div>
    
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = 'вҳҖпёҸ';
            } else {
                themeBtn.innerHTML = 'рҹҢҷ';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>