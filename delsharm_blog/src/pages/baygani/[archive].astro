---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
    const allPosts = await getCollection('blog');
    const archivesMap = new Map();
    
    allPosts.forEach(post => {
        let archiveLabel = "نامشخص";
        if (post.data.jalaliDate) {
            // Extracts "Month Year" (e.g., "مرداد ۱۴۰۲") from "12 مرداد 1402"
            const parts = post.data.jalaliDate.split(" ");
            if (parts.length >= 3) {
                archiveLabel = `${parts[1]} ${parts[2]}`; 
            }
        }

        if (!archivesMap.has(archiveLabel)) {
            archivesMap.set(archiveLabel, []);
        }
        archivesMap.get(archiveLabel).push(post);
    });

    return Array.from(archivesMap.entries()).map(([archive, posts]) => {
        // Safely sort posts chronologically
        posts.sort((a, b) => {
            const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
            const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
            return dateB - dateA;
        });
        return {
            params: { archive },
            props: { posts, allPosts }
        };
    });
}

const { archive } = Astro.params;
const { posts, allPosts } = Astro.props;

// Rebuild sidebar data for the sub-page
const tagCounts: Record<string, number> = {};
const archiveCounts: Record<string, number> = {};

allPosts.forEach(post => {
    const pTitle = post.data.title || "—";
    const pTags = post.data.tags ? [...post.data.tags] : [];
    if (pTitle === "—" && !pTags.includes("سیاه‌مشق")) {
        pTags.push("سیاه‌مشق");
    }

    pTags.forEach(t => {
        tagCounts[t] = (tagCounts[t] || 0) + 1;
    });

    let archLabel = "نامشخص";
    if (post.data.jalaliDate) {
        const parts = post.data.jalaliDate.split(" ");
        if (parts.length >= 3) {
            archLabel = `${parts[1]} ${parts[2]}`; 
        }
    }
    archiveCounts[archLabel] = (archiveCounts[archLabel] || 0) + 1;
});

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
// Define the Persian calendar order
const persianMonths = [
    "فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور",
    "مهر", "آبان", "آذر", "دی", "بهمن", "اسفند"
];

// Helper function to convert a label like "اسفند ۱۳۸۷" into a sortable number (e.g., 138711)
function getArchiveSortValue(label: string) {
    if (label === "نامشخص") return 0;
    
    const parts = label.split(" ");
    if (parts.length !== 2) return 0;
    
    const monthName = parts[0];
    const yearStr = parts[1];
    
    // Convert Persian year digits to English digits so JavaScript can do math on them
    const enYear = yearStr.replace(/[۰-۹]/g, (w) => '۰۱۲۳۴۵۶۷۸۹'.indexOf(w).toString());
    const year = parseInt(enYear, 10);
    
    const monthIndex = persianMonths.indexOf(monthName);
    
    if (isNaN(year) || monthIndex === -1) return 0;
    
    // Prioritize the year, then the month
    return (year * 100) + monthIndex;
}

// Sort chronologically (newest first) instead of by post count
const sortedArchives = Object.keys(archiveCounts).map(label => ({
    label,
    count: archiveCounts[label]
})).sort((a, b) => getArchiveSortValue(b.label) - getArchiveSortValue(a.label));

function toFa(num: number) {
    const farsiDigits = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
    return num.toString().replace(/\d/g, x => farsiDigits[parseInt(x)]);
}

function extractImage(bodyStr: string) {
    // Escaped \x3C and \x3E to prevent Astro JSX compiler crashes
    const imgRegex = /\x3Cimg[^\x3E]+src=["'](.*?)["']|!\[.*?\]\((.*?)\)/i;
    const match = bodyStr.match(imgRegex);
    return match ? (match[1] || match[2]) : null;
}

function generateExcerpt(markdownBody: string) {
    if (!markdownBody) return "<p>بدون محتوا</p>";

    let text = markdownBody;

    // 1. Nuke hidden blocks (styles, scripts, xml, comments)
    text = text.replace(/\x3Cstyle[^\x3E]*\x3E[\s\S]*?\x3C\/style\x3E/gi, ' ');
    text = text.replace(/\x3Cxml[^\x3E]*\x3E[\s\S]*?\x3C\/xml\x3E/gi, ' ');
    text = text.replace(/\x3Cscript[^\x3E]*\x3E[\s\S]*?\x3C\/script\x3E/gi, ' ');
    text = text.replace(/\x3C!--[\s\S]*?--\x3E/g, ' ');

    // 2. Strip Markdown links and images
    text = text.replace(/!\[.*?\]\(.*?\)/g, ' ');
    text = text.replace(/\[(.*?)\]\(.*?\)/g, '$1');

    // 3. RESCUE LINE BREAKS: Convert <br> and </p> to real newlines BEFORE stripping HTML
    text = text.replace(/\x3Cbr\s*\/?\x3E/gi, '\n');
    text = text.replace(/\x3C\/p\x3E/gi, '\n');
    text = text.replace(/\x3C\/div\x3E/gi, '\n');

    // 4. Strip ALL remaining HTML tags
    text = text.replace(/\x3C[^\x3E]+\x3E/g, ' ');

    // 5. Crush HTML Entities (&nbsp;, &zwnj;, etc.)
    text = text.replace(/&nbsp;/gi, ' ');
    text = text.replace(/&quot;/gi, '"');
    text = text.replace(/&amp;/gi, '&');
    text = text.replace(/&lt;/gi, '\x3C');
    text = text.replace(/&gt;/gi, '\x3E');
    text = text.replace(/&#?[a-z0-9]+;/gi, ' ');

    // 6. Clean up Markdown formatting characters
    text = text.replace(/[#*~_>]/g, '');

    // 7. Aggressively normalize whitespace and newlines
    text = text.replace(/[ \t]+/g, ' ').trim(); // All horizontal space becomes 1 space
    text = text.replace(/ *[\r\n]+ */g, '\n');  // Remove trailing spaces around newlines
    text = text.replace(/\n+/g, '\n');          // Multiple empty lines become 1 line

    // 8. Safely cut to 350 characters
    if (text.length > 350) {
        text = text.substring(0, 350) + '...';
    }
    
    // 9. Convert clean newlines back to HTML breaks for the preview card
    text = text.replace(/\n/g, '<br/>');
    
    return `<p>${text}</p>`;
}
---

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بایگانی: {archive} | دلشرم</title>
    <script is:inline>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark-mode');
        }
    </script>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <button id="theme-toggle" class="theme-toggle-btn" aria-label="تغییر تم">🌙</button>
            <a href="/delsharm" style="float: right; font-weight: bold;">← بازگشت</a>
            <h1><a href="/delsharm" style="color: inherit; text-decoration: none;">دلشرم</a></h1>
            <p style="color: var(--text-muted); margin-top: 10px; font-size: 1.1em;">محمدصادق رسولی</p>
            <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 20px 0;">
            <h2 style="margin: 0; font-size: 1.5em; text-align: center;">بایگانی نوشته‌ها: {archive}</h2>
            <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; text-align: center;">{toFa(posts.length)} نوشته یافت شد</p>
        </div>
        
        <div class="main-layout">
            <div class="content-area">
                <div class="posts-grid">
                    
                    {posts.map((post) => (
                        <div class="post-card">
                            {extractImage(post.body) && (
                                <a href={`/delsharm/blog/${post.id}/`}>
                                    <img src={extractImage(post.body)} class="card-img" alt="تصویر پست" />
                                </a>
                            )}
                            <div class="card-content">
                                <h2><a href={`/delsharm/blog/${post.id}/`}>{post.data.title}</a></h2>
                                
                                {post.data.jalaliDate && (
                                    <div class="date">{post.data.jalaliDate}</div>
                                )}
                                
                                <div class="excerpt-container" set:html={generateExcerpt(post.body)}></div>
                                
                                <a href={`/delsharm/blog/${post.id}/`} class="read-more">ادامه مطلب ←</a>
                            </div>
                        </div>
                    ))}
                    
                </div>
            </div>

            <div class="sidebar-area">
                <div class="section-title">موضوعات پرطرفدار</div>
                <div class="tags-grid">
                    {sortedTags.map(([t, count]) => (
                        <a href={`/delsharm/tags/${t}/`} class="tag-tile">
                            <span class="tag-name">{t}</span>
                            <span class="tag-count">{toFa(count)}</span>
                        </a>
                    ))}
                </div>
                
                <div class="section-title">بایگانی ماهانه</div>
                <div class="tags-grid">
                    {sortedArchives.map(arch => (
                        <a href={`/delsharm/baygani/${arch.label}/`} class="baygani-tile">
                            <span class="tag-name">{arch.label}</span>
                            <span class="tag-count">{toFa(arch.count)}</span>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </div>
    
    <script is:inline>
        const themeBtn = document.getElementById('theme-toggle');
        function updateIcon() {
            if (document.documentElement.classList.contains('dark-mode')) {
                themeBtn.innerHTML = '☀️';
            } else {
                themeBtn.innerHTML = '🌙';
            }
        }
        updateIcon();
        themeBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark-mode');
            const isDark = document.documentElement.classList.contains('dark-mode');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateIcon();
        });
    </script>
</body>
</html>